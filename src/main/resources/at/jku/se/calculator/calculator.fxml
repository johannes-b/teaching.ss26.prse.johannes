<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane fx:controller="at.jku.se.calculator.CalculatorFXController"
          xmlns:fx="http://javafx.com/fxml"
          hgap="4" vgap="4">
    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>

    <!-- Display -->
    <TextField fx:id="display" text="0" editable="false"
               style="-fx-font-size: 20px; -fx-font-family: Consolas; -fx-alignment: center-right;"
               GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="4"
               maxWidth="Infinity"/>

    <!-- Row 1: 7  8  9  / -->
    <Button text="7"   onAction="#onDigit"    userData="7"   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <Button text="8"   onAction="#onDigit"    userData="8"   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    <Button text="9"   onAction="#onDigit"    userData="9"   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
    <Button text="/"   onAction="#onOperator" userData="DIV" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

    <!-- Row 2: 4  5  6  × -->
    <Button text="4"   onAction="#onDigit"    userData="4"    maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
    <Button text="5"   onAction="#onDigit"    userData="5"    maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    <Button text="6"   onAction="#onDigit"    userData="6"    maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
    <Button text="x"   onAction="#onOperator" userData="MULT" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

    <!-- Row 3: 1  2  3  − -->
    <Button text="1"   onAction="#onDigit"    userData="1"   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
    <Button text="2"   onAction="#onDigit"    userData="2"   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    <Button text="3"   onAction="#onDigit"    userData="3"   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
    <Button text="-"   onAction="#onOperator" userData="SUB" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

    <!-- Row 4: 0  CE  =  + -->
    <Button text="0"   onAction="#onDigit"    userData="0"   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
    <Button text="CE"  onAction="#onClear"                   maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    <Button text="="   onAction="#onEquals"                  maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
    <Button text="+"   onAction="#onOperator" userData="ADD" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="4"/>

    <!-- Row 5: x^y spans all columns -->
    <Button text="x^y" onAction="#onOperator" userData="POW" maxWidth="Infinity" maxHeight="Infinity"
            GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="4"/>

    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS" minWidth="60"/>
        <ColumnConstraints hgrow="ALWAYS" minWidth="60"/>
        <ColumnConstraints hgrow="ALWAYS" minWidth="60"/>
        <ColumnConstraints hgrow="ALWAYS" minWidth="60"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints vgrow="NEVER"/>
        <RowConstraints vgrow="ALWAYS" minHeight="45"/>
        <RowConstraints vgrow="ALWAYS" minHeight="45"/>
        <RowConstraints vgrow="ALWAYS" minHeight="45"/>
        <RowConstraints vgrow="ALWAYS" minHeight="45"/>
        <RowConstraints vgrow="ALWAYS" minHeight="45"/>
    </rowConstraints>
</GridPane>
